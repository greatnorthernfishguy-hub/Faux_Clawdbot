{
  "spec_version": "1.0.0",
  "block": {
    "id": "BLK-NG-193",
    "name": "Add SimpleVectorDB persistence — cold-restart recall (#193)",
    "agent": "codemine",
    "scope": "Faux_Clawdbot",
    "acceptance_criteria": [
      "SimpleVectorDB.save(path) and .load(path) present in universal_ingestor.py",
      "NeuroGraphMemory.__init__ loads vector_db.npz sidecar on init if it exists",
      "NeuroGraphMemory.save() writes vector_db.npz alongside main.msgpack",
      "Smoke test: ingest -> save -> fresh NeuroGraphMemory instance -> vector_db.count() > 0",
      "python3 -m py_compile passes on both modified files"
    ]
  },
  "constraints": {
    "never": ["Do not modify any file other than universal_ingestor.py and openclaw_hook.py", "Do not restart any running service", "Do not remove any existing SimpleVectorDB methods"],
    "anti_drift": ["Only add save/load to SimpleVectorDB and wire them into NeuroGraphMemory save/init. Nothing else."],
    "tool_allowlist": ["shell_execute"],
    "shell_allowlist": ["python3", "git", "echo", "rm"]
  },
  "steps": [
    {
      "id": "idempotency_check",
      "type": "action",
      "description": "Count save(self, path) in universal_ingestor.py — 0 means patch not yet applied",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"print(open('universal_ingestor.py').read().count('def save(self, path: str)'))\""
      },
      "bind_result": "$step_count",
      "validation": { "checks": [{ "operator": "result_is_string" }] },
      "on_failure": "abort"
    },
    {
      "id": "apply_patch",
      "type": "condition",
      "description": "Apply patches if not already applied",
      "check": { "target": "$step_count", "operator": "equals", "value": "0" },
      "if_true": [
        {
          "id": "write_patch_script",
          "type": "action",
          "description": "Write BLK-NG-193 patch script to /tmp",
          "tool": "shell_execute",
          "params": {
            "command": "python3 -c \"import base64; open('/tmp/ng193_patch.py','wb').write(base64.b64decode(''))\" && echo SCRIPT_WRITTEN"
          },
          "validation": { "checks": [{ "operator": "contains", "value": "SCRIPT_WRITTEN" }] },
          "on_failure": "abort"
        },
        {
          "id": "run_patch_script",
          "type": "action",
          "description": "Apply patches to universal_ingestor.py and openclaw_hook.py",
          "tool": "shell_execute",
          "params": {
            "command": "python3 /tmp/ng193_patch.py"
          },
          "validation": { "checks": [{ "operator": "contains", "value": "PATCH_APPLIED" }] },
          "on_failure": "abort"
        }
      ],
      "if_false": [
        {
          "id": "already_applied",
          "type": "action",
          "description": "Patch already applied — skip to verification",
          "tool": "shell_execute",
          "params": { "command": "echo ALREADY_APPLIED" },
          "validation": { "checks": [{ "operator": "contains", "value": "ALREADY_APPLIED" }] },
          "on_failure": "abort"
        }
      ]
    },
    {
      "id": "syntax_check",
      "type": "action",
      "description": "Verify both patched files compile cleanly",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -m py_compile universal_ingestor.py && python3 -m py_compile openclaw_hook.py && echo SYNTAX_OK"
      },
      "validation": { "checks": [{ "operator": "contains", "value": "SYNTAX_OK" }] },
      "on_failure": "abort"
    },
    {
      "id": "smoke_test",
      "type": "action",
      "description": "Ingest a message, save, restore fresh instance — verify vectors survive cold restart",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"import os,sys,tempfile,shutil\nsys.path.insert(0,'.')\nfrom openclaw_hook import NeuroGraphMemory\ntmp=tempfile.mkdtemp()\ntry:\n    ng=NeuroGraphMemory(workspace_dir=tmp)\n    ng.on_message('test vector persistence BLK-NG-193')\n    ng.save()\n    c1=ng.vector_db.count()\n    ng2=NeuroGraphMemory(workspace_dir=tmp)\n    c2=ng2.vector_db.count()\n    if c1>0 and c2>0:\n        print(f'SMOKE_OK before={c1} restored={c2}')\n    else:\n        print(f'SMOKE_FAIL before={c1} restored={c2}',file=sys.stderr)\n        sys.exit(1)\nfinally:\n    shutil.rmtree(tmp,ignore_errors=True)\n\""
      },
      "validation": { "checks": [{ "operator": "contains", "value": "SMOKE_OK" }] },
      "on_failure": "abort"
    },
    {
      "id": "verify_sentinels",
      "type": "action",
      "description": "Confirm all key strings present in both patched files",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"import sys\nui=open('universal_ingestor.py').read()\noh=open('openclaw_hook.py').read()\nchecks=[('universal_ingestor.py','def save(self, path: str)',ui),('universal_ingestor.py','def load(self, path: str)',ui),('openclaw_hook.py','_vector_db_path',oh),('openclaw_hook.py','vector_db.save(',oh),('openclaw_hook.py','vector_db.load(',oh),('universal_ingestor.py','BLK-NG-193',ui),('openclaw_hook.py','BLK-NG-193',oh)]\nmissing=[(f,s) for f,s,src in checks if s not in src]\n[print(f'MISSING {f}: {s}',file=sys.stderr) for f,s in missing]\nif missing:sys.exit(1)\nprint('ALL_SENTINELS_PRESENT')\n\""
      },
      "validation": { "checks": [{ "operator": "contains", "value": "ALL_SENTINELS_PRESENT" }] },
      "on_failure": "abort"
    },
    {
      "id": "commit_and_push",
      "type": "action",
      "description": "Commit both patched files and push to GitHub",
      "tool": "shell_execute",
      "params": {
        "command": "cd /home/josh/Faux_Clawdbot && git add universal_ingestor.py openclaw_hook.py && git diff --cached --quiet && echo ALREADY_COMMITTED || (git commit -m 'Add SimpleVectorDB persistence — vector_db.npz sidecar (BLK-NG-193)' && git push && echo COMMITTED)"
      },
      "validation": { "checks": [{ "operator": "contains", "value": "COMMIT" }] },
      "on_failure": "abort"
    }
  ]
}

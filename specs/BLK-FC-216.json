{
  "spec_version": "1.0.0",
  "block": {
    "id": "BLK-FC-216",
    "name": "universal_ingestor.py: re-vendor from NeuroGraph canonical (embedding dim lock, msgpack format, _resolve_device)",
    "agent": "QB",
    "scope": "Faux_Clawdbot universal_ingestor.py is stale on 3 load-bearing fixes vs NeuroGraph canonical: (1) allow_pickle=True on np.load (security risk, deprecated). (2) Embedding dim read from config instead of locked to 768. (3) Missing _resolve_device() CUDA hardening. Fix: clone NeuroGraph canonical, verify all 3 fixes present, copy file over Faux_Clawdbot copy.",
    "acceptance_criteria": [
      "allow_pickle absent from Faux_Clawdbot/universal_ingestor.py (count 0)",
      "all-mpnet-base-v2 references absent from Faux_Clawdbot/universal_ingestor.py (count 0)",
      "_resolve_device present in Faux_Clawdbot/universal_ingestor.py (count 3)",
      "python3 -m py_compile Faux_Clawdbot/universal_ingestor.py passes",
      "Faux_Clawdbot committed and pushed"
    ]
  },
  "snap_interface": {
    "inputs": [],
    "outputs": [
      {
        "name": "universal_ingestor.py",
        "type": "file",
        "path": "Faux_Clawdbot/universal_ingestor.py",
        "contract": "Re-vendored from NeuroGraph canonical: no allow_pickle, no all-mpnet-base-v2 references, _resolve_device present (count 3)"
      }
    ]
  },
  "constraints": {
    "never": [
      "Do not modify NeuroGraph/universal_ingestor.py — it is a read-only source",
      "Do not patch Faux_Clawdbot/universal_ingestor.py with targeted edits — copy from canonical only",
      "Do not use sed or awk on source files",
      "Do not restart any service"
    ],
    "anti_drift": [
      "Verify canonical has _resolve_device (count 3) AND no allow_pickle (count 0) BEFORE copying — abort if canonical is wrong",
      "Use cp to replace Faux_Clawdbot/universal_ingestor.py with NeuroGraph/universal_ingestor.py — no partial edits",
      "Remove NeuroGraph clone after copy — it was read-only source material, on_failure: continue for cleanup"
    ],
    "tool_allowlist": ["write_file", "edit_file", "shell_execute", "read_file"],
    "shell_allowlist": ["python3", "git", "rm", "cp", "echo"]
  },
  "steps": [
    {
      "id": "check_token",
      "type": "action",
      "description": "Verify GITHUB_TOKEN is available for clone and push",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"import os; t=os.environ.get('GITHUB_TOKEN',''); print('TOKEN_OK' if t else 'TOKEN_MISSING')\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "TOKEN_OK"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "cleanup_workspace",
      "type": "action",
      "description": "Remove stale clone directories from any previous run",
      "tool": "shell_execute",
      "params": {
        "command": "rm -rf Faux_Clawdbot NeuroGraph && echo CLEANED"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "CLEANED"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "clone_faux_clawdbot",
      "type": "action",
      "description": "Clone Faux_Clawdbot repo (target to modify)",
      "tool": "shell_execute",
      "params": {
        "command": "git clone --depth 1 https://${GITHUB_TOKEN}@github.com/greatnorthernfishguy-hub/Faux_Clawdbot Faux_Clawdbot && echo FC_CLONED"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "FC_CLONED"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "clone_neurograph",
      "type": "action",
      "description": "Clone NeuroGraph canonical (read source only — no push to this repo)",
      "tool": "shell_execute",
      "params": {
        "command": "git clone --depth 1 https://${GITHUB_TOKEN}@github.com/greatnorthernfishguy-hub/NeuroGraph NeuroGraph && echo NG_CLONED"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "NG_CLONED"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_canonical_has_resolve_device",
      "type": "action",
      "description": "Confirm canonical has _resolve_device (count 3) before copying — fail fast if source is wrong",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('NeuroGraph/universal_ingestor.py').read(); print(c.count('_resolve_device'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "3"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_canonical_no_allow_pickle",
      "type": "action",
      "description": "Confirm canonical has no allow_pickle before copying — fail fast if source is wrong",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('NeuroGraph/universal_ingestor.py').read(); print(c.count('allow_pickle'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "0"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "copy_canonical",
      "type": "action",
      "description": "Replace Faux_Clawdbot universal_ingestor.py with NeuroGraph canonical",
      "tool": "shell_execute",
      "params": {
        "command": "cp NeuroGraph/universal_ingestor.py Faux_Clawdbot/universal_ingestor.py && echo COPY_OK"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "COPY_OK"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_allow_pickle_absent",
      "type": "action",
      "description": "Verify allow_pickle is gone from vendored file",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('Faux_Clawdbot/universal_ingestor.py').read(); print(c.count('allow_pickle'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "0"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_old_model_absent",
      "type": "action",
      "description": "Verify stale all-mpnet-base-v2 model references are gone",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('Faux_Clawdbot/universal_ingestor.py').read(); print(c.count('all-mpnet-base-v2'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "0"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_resolve_device_present",
      "type": "action",
      "description": "Verify _resolve_device() CUDA hardening is present (count 3)",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('Faux_Clawdbot/universal_ingestor.py').read(); print(c.count('_resolve_device'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "3"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "compile_check",
      "type": "action",
      "description": "Verify vendored universal_ingestor.py compiles cleanly",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -m py_compile Faux_Clawdbot/universal_ingestor.py && echo COMPILE_OK"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "COMPILE_OK"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "cleanup_clone",
      "type": "action",
      "description": "Remove NeuroGraph clone — no longer needed",
      "tool": "shell_execute",
      "params": {
        "command": "rm -rf NeuroGraph && echo CLEANED"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "CLEANED"}]
      },
      "on_failure": "continue"
    },
    {
      "id": "commit_push",
      "type": "action",
      "description": "Commit and push re-vendored universal_ingestor.py; treat already-committed as success",
      "tool": "shell_execute",
      "params": {
        "command": "git -C Faux_Clawdbot config user.email 'codemine@et-systems.ai' && git -C Faux_Clawdbot config user.name 'Codemine (QB)' && git -C Faux_Clawdbot add universal_ingestor.py && git -C Faux_Clawdbot diff --cached --quiet && echo ALREADY_COMMITTED || (git -C Faux_Clawdbot commit -m 're-vendor(universal_ingestor): sync from NeuroGraph canonical — dim lock, msgpack, _resolve_device (#216)' && git -C Faux_Clawdbot push && echo COMMITTED)"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "COMMIT"}]
      },
      "on_failure": "abort"
    }
  ]
}

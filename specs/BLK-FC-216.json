{
  "spec_id": "BLK-FC-216",
  "title": "universal_ingestor.py: re-vendor from NeuroGraph canonical (embedding dim lock, msgpack format, _resolve_device)",
  "punchlist_item": 216,
  "workspace": ".",
  "shell_allowlist": ["python3", "git", "rm", "cp", "echo"],
  "constraints": {
    "read_only_paths": []
  },
  "steps": [
    {
      "id": "check_token",
      "type": "action",
      "description": "Verify GITHUB_TOKEN is available for clone and push",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"import os; t=os.environ.get('GITHUB_TOKEN',''); print('TOKEN_OK' if t else 'TOKEN_MISSING')\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "TOKEN_OK"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "idempotency_check",
      "type": "action",
      "description": "Skip if allow_pickle already absent — re-vendor already applied",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('universal_ingestor.py').read(); print('ALREADY_VENDORED' if c.count('allow_pickle') == 0 else 'NEEDS_VENDOR')\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "NEEDS_VENDOR"}]
      },
      "on_failure": "skip_all"
    },
    {
      "id": "cleanup_workspace",
      "type": "action",
      "description": "Remove any stale NeuroGraph clone from a previous run",
      "tool": "shell_execute",
      "params": {
        "command": "rm -rf NeuroGraph && echo CLEANED"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "CLEANED"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "clone_neurograph",
      "type": "action",
      "description": "Clone NeuroGraph canonical (read source only — no push to this repo)",
      "tool": "shell_execute",
      "params": {
        "command": "git clone --depth 1 https://${GITHUB_TOKEN}@github.com/greatnorthernfishguy-hub/NeuroGraph NeuroGraph && echo CLONE_OK"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "CLONE_OK"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_canonical_has_resolve_device",
      "type": "action",
      "description": "Confirm canonical has _resolve_device before copying (fail fast if something is wrong with the source)",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('NeuroGraph/universal_ingestor.py').read(); print(c.count('_resolve_device'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "3"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_canonical_no_allow_pickle",
      "type": "action",
      "description": "Confirm canonical has no allow_pickle before copying",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('NeuroGraph/universal_ingestor.py').read(); print(c.count('allow_pickle'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "0"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "copy_canonical",
      "type": "action",
      "description": "Replace Faux_Clawdbot universal_ingestor.py with NeuroGraph canonical",
      "tool": "shell_execute",
      "params": {
        "command": "cp NeuroGraph/universal_ingestor.py universal_ingestor.py && echo COPY_OK"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "COPY_OK"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_allow_pickle_absent",
      "type": "action",
      "description": "Verify allow_pickle is gone from vendored file",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('universal_ingestor.py').read(); print(c.count('allow_pickle'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "0"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_old_model_absent",
      "type": "action",
      "description": "Verify stale all-mpnet-base-v2 model references are gone",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('universal_ingestor.py').read(); print(c.count('all-mpnet-base-v2'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "0"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "verify_resolve_device_present",
      "type": "action",
      "description": "Verify _resolve_device() CUDA hardening is present",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -c \"c=open('universal_ingestor.py').read(); print(c.count('_resolve_device'))\""
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "3"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "compile_check",
      "type": "action",
      "description": "Verify vendored universal_ingestor.py compiles cleanly",
      "tool": "shell_execute",
      "params": {
        "command": "python3 -m py_compile universal_ingestor.py && echo COMPILE_OK"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "COMPILE_OK"}]
      },
      "on_failure": "abort"
    },
    {
      "id": "cleanup_clone",
      "type": "action",
      "description": "Remove NeuroGraph clone — no longer needed",
      "tool": "shell_execute",
      "params": {
        "command": "rm -rf NeuroGraph && echo CLEANED"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "CLEANED"}]
      },
      "on_failure": "continue"
    },
    {
      "id": "commit_push",
      "type": "action",
      "description": "Commit and push re-vendored universal_ingestor.py; treat already-committed as success",
      "tool": "shell_execute",
      "params": {
        "command": "git add universal_ingestor.py && git diff --cached --quiet && echo ALREADY_COMMITTED || (git commit -m 're-vendor(universal_ingestor): sync from NeuroGraph canonical — dim lock, msgpack, _resolve_device (#216)' && git push && echo COMMITTED)"
      },
      "validation": {
        "checks": [{"operator": "contains", "value": "COMMIT"}]
      },
      "on_failure": "abort"
    }
  ]
}
